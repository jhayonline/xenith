# Comprehensive Xenith Language Test
# This program tests all major features of the language

#######################################
# 1. BASIC OUTPUT AND COMMENTS
#######################################

echo("=" * 50)
echo("XENITH LANGUAGE TEST SUITE")
echo("=" * 50)
echo("")

# This is a single-line comment
echo("1. BASIC OUTPUT:")
echo("   Hello, World!")
echo("   String concatenation: Hello World")
echo("")

#######################################
# 2. VARIABLES (spawn)
#######################################

echo("2. VARIABLES:")

spawn age = 25
spawn name = "Alice"
spawn pi = 3.14159

echo("   age = {age}")
echo("   name = {name}")
echo("   pi = {pi}")

# Variable reassignment (no spawn keyword needed!)
age = 26
echo("   age (updated) = {age}")
echo("")

#######################################
# 3. ARITHMETIC OPERATIONS
#######################################

echo("3. ARITHMETIC:")

spawn a = 10
spawn b = 3

echo("   a = {a}, b = {b}")
echo("   a + b = {a + b}")
echo("   a - b = {a - b}")
echo("   a * b = {a * b}")
echo("   a / b = {a / b}")
echo("   a ^ b = {a ^ b}")
echo("   -a = {-a}")
echo("")

#######################################
# 4. COMPARISON OPERATORS
#######################################

echo("4. COMPARISONS:")

spawn x = 5
spawn y = 10
spawn z = 5

echo("   x = {x}, y = {y}, z = {z}")
echo("   x == z -> {x == z}")
echo("   x != y -> {x != y}")
echo("   x < y -> {x < y}")
echo("   y > x -> {y > x}")
echo("   x <= 5 -> {x <= 5}")
echo("   y >= 10 -> {y >= 10}")
echo("")

#######################################
# 5. LOGICAL OPERATORS
#######################################

echo("5. LOGICAL OPERATORS:")

spawn t = 1
spawn f = 0

echo("   TRUE = {t}, FALSE = {f}")
echo("   t && t -> {t && t}")
echo("   t && f -> {t && f}")
echo("   t || f -> {t || f}")
echo("   f || f -> {f || f}")
echo("   !t -> {!t}")
echo("   !f -> {!f}")
echo("")

#######################################
# 6. CONTROL FLOW
#######################################

echo("6. CONTROL FLOW:")

spawn score = 85

when score >= 90 {
    echo("   Grade: A")
} or when score >= 80 {
    echo("   Grade: B")
} or when score >= 70 {
    echo("   Grade: C")
} otherwise {
    echo("   Grade: F")
}

spawn outer = 10
spawn inner = 20

when outer > 5 {
    when inner > 15 {
        echo("   Nested condition passed!")
    }
}
echo("")

#######################################
# 7. TERNARY OPERATOR
#######################################

echo("7. TERNARY OPERATOR:")

spawn age2 = 18
spawn status = age2 >= 18 ? "Adult" : "Minor"
echo("   age {age2} -> {status}")

spawn age3 = 16
spawn status2 = age3 >= 18 ? "Adult" : "Minor"
echo("   age {age3} -> {status2}")
echo("")

#######################################
# 8. LISTS WITH MODERN SYNTAX
#######################################

echo("8. LISTS (Modern Syntax):")

spawn fruits = ["apple", "banana", "orange"]
echo("   Original list: {ret(fruits)}")

# Modern indexing with []
echo("   fruits[0] = {fruits[0]}")
echo("   fruits[1] = {fruits[1]}")
echo("   fruits[2] = {fruits[2]}")

# Modern method syntax - modifies in place
fruits.append("grape")
echo("   After append: {ret(fruits)}")

spawn popped = fruits.pop(1)
echo("   Popped index 1: {popped}")
echo("   List after pop: {ret(fruits)}")

echo("   List length: {fruits.len()}")

# List concatenation (returns new list)
spawn list1 = [1, 2, 3]
spawn list2 = [4, 5, 6]
spawn combined = list1 + list2
echo("   Concatenated: {ret(combined)}")

# Nested list indexing
spawn matrix = [[1, 2], [3, 4], [5, 6]]
echo("   matrix[1][0] = {matrix[1][0]}")
echo("")

#######################################
# 9. LOOPS
#######################################

echo("9. LOOPS:")

echo("   FOR loop 0 to 4:")
for i = 0 to 5 {
    echo("     i = {i}")
}

echo("   FOR loop with STEP 2:")
for i = 0 to 10 step 2 {
    echo("     i = {i}")
}

echo("   FOR loop with negative STEP:")
for i = 5 to 0 step -1 {
    echo("     i = {i}")
}

echo("   WHILE loop countdown:")
spawn count = 3
while count > 0 {
    echo("     countdown: {count}")
    count = count - 1
}

echo("   BREAK example:")
for i = 0 to 10 {
    when i == 5 {
        stop
    }
    echo("     i = {i}")
}

echo("   CONTINUE example:")
for i = 0 to 5 {
    when i == 3 {
        skip
    }
    echo("     i = {i}")
}
echo("")

#######################################
# 10. FUNCTIONS
#######################################

echo("10. FUNCTIONS:")

method greet(name) {
    release "Hello, {name}!"
}

echo("   greet(\"Bob\") = {greet("Bob")}")

method add(a, b) {
    release a + b
}

echo("   add(5, 3) = {add(5, 3)}")

method double(x) -> x * 2
echo("   double(7) = {double(7)}")

method factorial(n) {
    spawn result = 1
    spawn i = 1
    while i <= n {
        result = result * i
        i = i + 1
    }
    release result
}

echo("   factorial(5) = {factorial(5)}")

method range(n) {
    spawn result = []
    spawn i = 0
    while i < n {
        result.append(i)  # In-place modification, no reassignment needed
        i = i + 1
    }
    release result
}

echo("   range(5) = {ret(range(5))}")

spawn my_double = double
echo("   my_double(10) = {my_double(10)}")
echo("")

#######################################
# 11. BUILT-IN FUNCTIONS
#######################################

echo("11. BUILT-IN FUNCTIONS:")

echo("   is_num(42): {is_num(42)}")
echo("   is_num(\"hello\"): {is_num("hello")}")
echo("   is_str(\"hello\"): {is_str("hello")}")
echo("   is_list([1,2,3]): {is_list([1, 2, 3])}")
echo("   is_fun(double): {is_fun(double)}")

echo("   MATH_PI = {MATH_PI}")
echo("   TRUE = {TRUE}")
echo("   FALSE = {FALSE}")
echo("   NULL = {NULL}")
echo("")

#######################################
# 12. FIBONACCI
#######################################

echo("12. FIBONACCI SEQUENCE:")

method fibonacci(n) {
    when n <= 1 {
        release n
    }
    spawn a = 0
    spawn b = 1
    spawn i = 2
    while i <= n {
        spawn c = a + b
        a = b
        b = c
        i = i + 1
    }
    release b
}

echo("   fibonacci(0) = {fibonacci(0)}")
echo("   fibonacci(1) = {fibonacci(1)}")
echo("   fibonacci(2) = {fibonacci(2)}")
echo("   fibonacci(5) = {fibonacci(5)}")
echo("   fibonacci(8) = {fibonacci(8)}")
echo("")

#######################################
# 13. DATA PROCESSING WITH MODERN SYNTAX
#######################################

echo("13. DATA PROCESSING (Modern Syntax):")

spawn alice = ["Alice", 85]
spawn bob = ["Bob", 62]
spawn charlie = ["Charlie", 95]
spawn diana = ["Diana", 78]

spawn students = []
students.append(alice)      # In-place modification
students.append(bob)
students.append(charlie)
students.append(diana)

method process_grades(student_list) {
    spawn results = []
    spawn total = 0.0
    spawn i = 0

    while i < student_list.len() {
        spawn student = student_list[i]
        spawn name = student[0]
        spawn score = student[1]

        spawn grade = "F"
        when score >= 90 {
            grade = "A"
        } or when score >= 80 {
            grade = "B"
        } or when score >= 70 {
            grade = "C"
        } or when score >= 60 {
            grade = "D"
        }

        # In-place modification
        results.append("{name}: {score} -> {grade}")  
        total = total + score
        i = i + 1
    }

    spawn average = total / student_list.len()
    release [results, average]
}

spawn processed = process_grades(students)
spawn grades = processed[0]
spawn avg = processed[1]

spawn j = 0
while j < grades.len() {
    echo("   {grades[j]}")
    j = j + 1
}
echo("   Class average: {avg}")
echo("")

#######################################
# 14. INCREMENT/DECREMENT OPERATORS
#######################################

echo("14. INCREMENT/DECREMENT OPERATORS:")

spawn counter = 5
echo("   Initial counter = {counter}")

counter++
echo("   After counter++: {counter}")

counter--
echo("   After counter--: {counter}")

spawn x = 10
x += 3
echo("   x += 3 -> {x}")

x -= 2
echo("   x -= 2 -> {x}")

# Post-increment as standalone statement
spawn y = 5
echo("   Initial y = {y}")
y++
echo("   After y++: {y}")

# Post-decrement as standalone statement
spawn z = 8
echo("   Initial z = {z}")
z--
echo("   After z--: {z}")

# Compound assignment with variables
spawn a = 7
a += a
echo("   a += a -> {a}")

spawn b = 10
b -= 3
echo("   b -= 3 -> {b}")

echo("")

#######################################
# 15. TEST SUMMARY
#######################################

echo("")
echo("=" * 50)
echo("TEST COMPLETE")
echo("=" * 50)
echo("")
echo("If you see this message, all tests passed!")
echo("")
