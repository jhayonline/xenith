# Xenith Error Handling Test
echo("=== Error Handling Test ===\n")

# Test 1: Basic try-catch with panic
echo("Test 1: Basic panic and catch")
try {
    echo("  Inside try block")
    panic "Something went wrong!"
    echo("  This line should not execute")
} catch err {
    echo("  Caught error: {err}")
}
echo("")

# Test 2: Catching runtime errors (division by zero)
echo("Test 2: Catching division by zero")
try {
    spawn x = 10 / 0
    echo("  Result: {x}")
} catch err {
    echo("  Caught error: {err}")
}
echo("")

# Test 3: No error - should execute normally
echo("Test 3: No error occurs")
try {
    spawn y = 42
    echo("  y = {y}")
} catch err {
    echo("  This should not execute: {err}")
}
echo("")

# Test 4: Nested try-catch
echo("Test 4: Nested try-catch")
try {
    echo("  Outer try")
    try {
        echo("    Inner try")
        panic "Inner error"
        echo("    This should not execute")
    } catch inner_err {
        echo("    Inner catch: {inner_err}")
    }
    echo("  Outer continues after inner catch")
} catch outer_err {
    echo("  Outer catch (should not happen): {outer_err}")
}
echo("")

# Test 5: Uncaught panic (should crash)
echo("Test 5: Uncaught panic (this will crash the program)")
echo("  About to panic...")
panic "This error is uncaught and should crash!"
echo("  This line should never execute")
