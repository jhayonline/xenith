# Test JSON by reading from file
grab { parse, stringify } from "std::json"  
grab { read } from "std::fs"

echo("=== JSON Test from File ===\n")

# Read JSON from file
let json_str: string = read("tests/data.json")
let data: json = parse(json_str)
echo("JSON parsed successfully from file!")

# Stringify and display
let output: string = stringify(data)
echo("Data: {output}")
