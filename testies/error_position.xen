grab { read } from "std::fs"

echo("Testing error positions...")

# This should show the correct file and line number
try {
    let content: string = read("nonexistent_file.txt")
} catch err {
    echo("Caught error: {err}")
}

# This should show the correct location for type errors
try {
    let path: int = 42
    let content: string = read(path)
} catch err {
    echo("Caught type error: {err}")
}
