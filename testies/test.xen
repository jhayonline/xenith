# Comprehensive Xenith Language Test - With Full Type System
# This program tests all major features of the language with explicit types

#######################################
# 1. BASIC OUTPUT AND COMMENTS
#######################################

echo("=" * 50)
echo("XENITH LANGUAGE TEST SUITE")
echo("=" * 50)
echo("")

# This is a single-line comment
echo("1. BASIC OUTPUT:")
echo("   Hello, World!")
echo("   String concatenation: Hello World")
echo("")

#######################################
# 2. VARIABLES (let)
#######################################

echo("2. VARIABLES:")

let age: int = 25
let name: string = "Alice"
let pi: float = 3.14159
let is_active: bool = true

echo("   age = {age}")
echo("   name = {name}")
echo("   pi = {pi}")
echo("   is_active = {is_active}")

# Variable reassignment (no let keyword needed!)
age = 26
echo("   age (updated) = {age}")
echo("")

# Test const let
const let MAX_SIZE: int = 100
echo("   MAX_SIZE = {MAX_SIZE}")
echo("")

#######################################
# 3. ARITHMETIC OPERATIONS
#######################################

echo("3. ARITHMETIC:")

let a: int = 10
let b: int = 3

echo("   a = {a}, b = {b}")
echo("   a + b = {a + b}")
echo("   a - b = {a - b}")
echo("   a * b = {a * b}")
echo("   a / b = {a / b}")
echo("   a ^ b = {a ^ b}")
echo("   -a = {-a}")
echo("")

#######################################
# 4. COMPARISON OPERATORS
#######################################

echo("4. COMPARISONS:")

let x: int = 5
let y: int = 10
let z: int = 5

echo("   x = {x}, y = {y}, z = {z}")
echo("   x == z -> {x == z}")
echo("   x != y -> {x != y}")
echo("   x < y -> {x < y}")
echo("   y > x -> {y > x}")
echo("   x <= 5 -> {x <= 5}")
echo("   y >= 10 -> {y >= 10}")
echo("")

#######################################
# 5. LOGICAL OPERATORS
#######################################

echo("5. LOGICAL OPERATORS:")

let t: bool = true
let f: bool = false

echo("   TRUE = {t}, FALSE = {f}")
echo("   t && t -> {t && t}")
echo("   t && f -> {t && f}")
echo("   t || f -> {t || f}")
echo("   f || f -> {f || f}")
echo("   !t -> {!t}")
echo("   !f -> {!f}")
echo("")

#######################################
# 6. CONTROL FLOW
#######################################

echo("6. CONTROL FLOW:")

let score: int = 85

when score >= 90 {
    echo("   Grade: A")
} or when score >= 80 {
    echo("   Grade: B")
} or when score >= 70 {
    echo("   Grade: C")
} otherwise {
    echo("   Grade: F")
}

let outer: int = 10
let inner: int = 20

when outer > 5 {
    when inner > 15 {
        echo("   Nested condition passed!")
    }
}
echo("")

#######################################
# 7. TERNARY OPERATOR
#######################################

echo("7. TERNARY OPERATOR:")

let age2: int = 18
let status: string = age2 >= 18 ? "Adult" : "Minor"
echo("   age {age2} -> {status}")

let age3: int = 16
let status2: string = age3 >= 18 ? "Adult" : "Minor"
echo("   age {age3} -> {status2}")
echo("")

#######################################
# 8. LISTS WITH MODERN SYNTAX
#######################################

echo("8. LISTS (Modern Syntax):")

let fruits: list<string> = ["apple", "banana", "orange"]
echo("   Original list: {ret(fruits)}")

# Modern indexing with []
echo("   fruits[0] = {fruits[0]}")
echo("   fruits[1] = {fruits[1]}")
echo("   fruits[2] = {fruits[2]}")

# Modern method syntax - modifies in place
fruits.append("grape")
echo("   After append: {ret(fruits)}")

let popped: string = fruits.pop(1)
echo("   Popped index 1: {popped}")
echo("   List after pop: {ret(fruits)}")

echo("   List length: {fruits.len()}")

# List concatenation (returns new list)
let list1: list<int> = [1, 2, 3]
let list2: list<int> = [4, 5, 6]
let combined: list<int> = list1 + list2
echo("   Concatenated: {ret(combined)}")

# Nested list indexing
let matrix: list<list<int>> = [[1, 2], [3, 4], [5, 6]]
echo("   matrix[1][0] = {matrix[1][0]}")
echo("")

#######################################
# 9. LOOPS
#######################################

echo("9. LOOPS:")

echo("   FOR loop 0 to 4:")
for i = 0 to 5 {
    echo("     i = {i}")
}

echo("   FOR loop with STEP 2:")
for i = 0 to 10 step 2 {
    echo("     i = {i}")
}

echo("   FOR loop with negative STEP:")
for i = 5 to 0 step -1 {
    echo("     i = {i}")
}

echo("   WHILE loop countdown:")
let count: int = 3
while count > 0 {
    echo("     countdown: {count}")
    count = count - 1
}

echo("   BREAK example:")
for i = 0 to 10 {
    when i == 5 {
        stop
    }
    echo("     i = {i}")
}

echo("   CONTINUE example:")
for i = 0 to 5 {
    when i == 3 {
        skip
    }
    echo("     i = {i}")
}
echo("")

#######################################
# 10. FUNCTIONS
#######################################

echo("10. FUNCTIONS:")

method greet(name: string) -> string {
    release "Hello, {name}!"
}

echo("   greet(\"Bob\") = {greet("Bob")}")

method add(a: int, b: int) -> int {
    release a + b
}

echo("   add(5, 3) = {add(5, 3)}")

method double(x: int) -> int => x * 2
echo("   double(7) = {double(7)}")

method factorial(n: int) -> int {
    when n <= 1 {
        release 1
    }
    release n * factorial(n - 1)
}

echo("   factorial(5) = {factorial(5)}")

method range(n: int) -> list<int> {
    let result: list<int> = []
    let i: int = 0
    while i < n {
        result.append(i)
        i = i + 1
    }
    release result
}

echo("   range(5) = {ret(range(5))}")

# type IntFunction = method(int) -> int
# let my_double: IntFunction = double
# echo("   my_double(10) = {my_double(10)}")

# Test void function
method log_message(msg: string) -> null {
    echo("   Log: {msg}")
    release null
}

log_message("Void function test")
echo("")

#######################################
# 11. MAPS
#######################################

echo("11. MAPS:")

# Test maps with types - use double quotes for keys
let user: map<string, int> = {"age": 25}
let scores: map<string, list<int>> = {"Alice": [100, 95, 90]}

echo("   User age: {user["age"]}")
echo("   Alice's scores: {ret(scores["Alice"])}")

# Map operations
echo("   Map keys: {ret(user.keys())}")
echo("   Map values: {ret(user.values())}")
echo("   Map has age? {user.has_key("age")}")
echo("")

#######################################
# 12. BUILT-IN FUNCTIONS
#######################################

echo("12. BUILT-IN FUNCTIONS:")

echo("   is_num(42): {is_num(42)}")
echo("   is_num(\"hello\"): {is_num("hello")}")
echo("   is_str(\"hello\"): {is_str("hello")}")
echo("   is_list([1,2,3]): {is_list([1, 2, 3])}")
echo("   is_fun(double): {is_fun(double)}")

echo("   MATH_PI = {MATH_PI}")
echo("   TRUE = {TRUE}")
echo("   FALSE = {FALSE}")
echo("   NULL = {NULL}")
echo("")

#######################################
# 13. FIBONACCI
#######################################

echo("13. FIBONACCI SEQUENCE:")

method fibonacci(n: int) -> int {
    when n <= 1 {
        release n
    }
    let a: int = 0
    let b: int = 1
    let i: int = 2
    while i <= n {
        let c: int = a + b
        a = b
        b = c
        i = i + 1
    }
    release b
}

echo("   fibonacci(0) = {fibonacci(0)}")
echo("   fibonacci(1) = {fibonacci(1)}")
echo("   fibonacci(2) = {fibonacci(2)}")
echo("   fibonacci(5) = {fibonacci(5)}")
echo("   fibonacci(8) = {fibonacci(8)}")
echo("")

#######################################
# 14. STRUCTS
#######################################

echo("14. STRUCTS:")

struct Student {
    name: string,
    score: int
}

let alice: Student = Student { name: "Alice", score: 85 }
let bob: Student = Student { name: "Bob", score: 62 }
let charlie: Student = Student { name: "Charlie", score: 95 }
let diana: Student = Student { name: "Diana", score: 78 }

echo("   Alice: {alice.name} = {alice.score}")
echo("   Bob: {bob.name} = {bob.score}")
echo("   Charlie: {charlie.name} = {charlie.score}")
echo("   Diana: {diana.name} = {diana.score}")

# Modify struct field
alice.score = 90
echo("   Alice updated score: {alice.score}")
echo("")

#######################################
# 15. DATA PROCESSING WITH STRUCTS
#######################################

echo("15. DATA PROCESSING:")

let students: list<Student> = [alice, bob, charlie, diana]

method process_grades(student_list: list<Student>) -> list<string> {
    let results: list<string> = []
    let i: int = 0

    while i < student_list.len() {
        let student: Student = student_list[i]
        let name: string = student.name
        let score: int = student.score

        let grade: string = "F"
        when score >= 90 {
            grade = "A"
        } or when score >= 80 {
            grade = "B"
        } or when score >= 70 {
            grade = "C"
        } or when score >= 60 {
            grade = "D"
        }

        results.append("{name}: {score} -> {grade}")
        i = i + 1
    }
    release results
}

let grades: list<string> = process_grades(students)

let j: int = 0
while j < grades.len() {
    echo("   {grades[j]}")
    j = j + 1
}
echo("")

#######################################
# 16. TYPE CONVERSION
#######################################

echo("16. TYPE CONVERSION:")

let int_val: int = 42
let float_val: float = int_val as float
let string_val: string = int_val as string
let bool_val: bool = int_val as bool

echo("   int 42 -> float: {float_val}")
echo("   int 42 -> string: {string_val}")
echo("   int 42 -> bool: {bool_val}")

let pi_val: float = 3.14159
let pi_int: int = pi_val as int
echo("   float 3.14159 -> int: {pi_int}")

let true_val: bool = true
let true_int: int = true_val as int
echo("   bool true -> int: {true_int}")
echo("")

