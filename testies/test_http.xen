grab { post, post_with_headers } from "std::http"
grab { parse, stringify, from_map, get, json_null } from "std::json"

echo("=== Testing HTTP POST ===\n")

# Test 1: POST with JSON map converted to json
echo("1. POST with JSON map converted to json:")
let data_map: map<string, json> = {
    "title": "Test Post",
    "body": "This is a test post",
    "userId": 1
}
let data: json = from_map(data_map)

try {
    let response: HttpResponse = post(`https://jsonplaceholder.typicode.com/posts`, data)
    echo("   Status: {response.status}")
    # Use HttpResponse::as_json(response) instead of response.as_json()
    let response_json: json = HttpResponse::as_json(response)
    echo("   Response: {stringify(response_json)}")
} catch err {
    echo("   Error: {err}")
}
echo("")

# Test 2: POST with JSON string
echo("2. POST with JSON string:")
let json_str: string = `{"title":"Test 2","body":"Another test","userId":2}`
let data2: json = parse(json_str)

try {
    let response: HttpResponse = post(`https://jsonplaceholder.typicode.com/posts`, data2)
    echo("   Status: {response.status}")
    echo("   Raw body:\n {response.body}")
    let created: json = HttpResponse::as_json(response)
    echo("   Full created: {stringify(created)}")
    # Use json::null instead of parse("null")
    let id_json: json = get(created, "id", json_null)
    let id_str: string = stringify(id_json)
    echo("   Created ID: {id_str}")
} catch err {
    echo("   Error: {err}")
}
echo("")

# Test 3: POST with custom headers
echo("3. POST with custom headers:")
let headers: map<string, string> = {
    "X-Custom-Header": "test-value"
}

try {
    let response: HttpResponse = post_with_headers(`https://jsonplaceholder.typicode.com/posts`, data, headers)
    echo("   Status: {response.status}")

    # Use HttpResponse::header(response, "x-custom-header")
    echo("   Custom header echoed back? {HttpResponse::header(response, "x-custom-header")}")
} catch err {
    echo("   Error: {err}")
}
echo("")

echo("=== All HTTP POST tests completed! ===")
