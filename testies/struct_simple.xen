# Test struct creation and field access

struct Person {
    name: string,
    age: int
}

# Create a struct instance
let alice: Person = Person {
    name: "Alice",
    age: 25
}

echo("Name: {alice.name}")
echo("Age: {alice.age}")

# Create another person
let bob: Person = Person {
    name: "Bob",
    age: 30
}

echo("Bob's name: {bob.name}")
echo("Bob's age: {bob.age}")
