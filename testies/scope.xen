# Test variable scoping with types
let x: int = 10
echo("Outer x: {x}")

method test() -> null {
    echo("Inside function - x before: {x}")
    x = 20  # This should update the outer x
    echo("Inside function - x after: {x}")
    release null
}

test()
echo("Outer x after function call: {x}")

# Test nested blocks
let y: int = 5
when y == 5 {
    echo("Inside block - y before: {y}")
    y = 15
    echo("Inside block - y after: {y}")
}
echo("Outer y after block: {y}")
