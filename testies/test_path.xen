grab { join, basename, dirname, extension, stem, is_absolute, is_relative, absolute, normalize, components, parent } from "std::path"

echo("=== Path Module Test ===\n")

# Test join
echo("1. Join paths:")
let joined: string = join(["/home", "user", "docs", "file.txt"])
echo("   {joined}\n")

# Test basename
echo("2. Basename:")
let base: string = basename("/home/user/file.txt")
echo("   {base}\n")

# Test dirname
echo("3. Dirname:")
let dir: string = dirname("/home/user/file.txt")
echo("   {dir}\n")

# Test extension
echo("4. Extension:")
let ext: string = extension("archive.tar.gz")
echo("   {ext}\n")

# Test stem
echo("5. Stem (name without extension):")
let name: string = stem("document.pdf")
echo("   {name}\n")

# Test is_absolute
echo("6. Is absolute?")
echo("   /home/user: {is_absolute("/home/user")}")
echo("   relative/path: {is_absolute("relative/path")}\n")

# Test is_relative
echo("7. Is relative?")
echo("   /home/user: {is_relative("/home/user")}")
echo("   relative/path: {is_relative("relative/path")}\n")

# Test absolute (may fail if file doesn't exist, but should work for existing paths)
echo("8. Absolute path (for current directory .):")
try {
    let abs: string = absolute(".")
    echo("   {abs}")
} catch err {
    echo("   Error: {err}")
}
echo("")

# Test normalize
echo("9. Normalize path:")
let norm: string = normalize("/home/./user/../user/docs/./file.txt")
echo("   {norm}\n")

# Test components
echo("10. Path components:")
let comps: list<string> = components("/home/user/docs/file.txt")
for i = 0 to comps.len() {
    echo("   {comps[i]}")
}
echo("")

# Test parent
echo("11. Parent directory:")
let parent_dir: string = parent("/home/user/docs/file.txt")
echo("   {parent_dir}\n")

echo("=== All tests completed! ===")
