grab { parse, stringify } from "std::json"

echo("=== Testing JSON with mixed types using any ===\n")

# Parse JSON with mixed types
let data: json = parse({
    "name": "Alice",
    "age": 25,
    "active": true,
    "scores": [95.5, 87, 92],
    "address": {
        "city": "New York",
        "zip": 10001
    }
})

echo("Data parsed successfully!")
echo("Name: {data["name"]}")
echo("Age: {data["age"]}")
echo("Active: {data["active"]}")
echo("First score: {data["scores"][0]}")

# Stringify back to JSON
let json_str: string = stringify(data)
echo("\nStringified JSON: {json_str}")
